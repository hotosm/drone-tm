SITE_NAME="DTM-Drone Tasking Manager"
BASE_URL=https://dronetm-api.naxa.com.np
API_URL_V1=https://dronetm-api.naxa.com.np/api

# Authentication Provider
# Options: "legacy" (Google OAuth) or "hanko" (HOTOSM SSO via Portal)
VITE_AUTH_PROVIDER=legacy

# HOTOSM Portal SSO (when VITE_AUTH_PROVIDER="hanko")
# For local development:
#   VITE_HANKO_URL: Login service URL (login.hotosm.org)
#   VITE_FRONTEND_URL: Drone-TM frontend URL (for return URLs)
# For production:
#   VITE_HANKO_URL=https://login.hotosm.org
VITE_HANKO_URL=http://localhost:8002
VITE_FRONTEND_URL=http://localhost:3000

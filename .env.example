### PUBLIC ROUTING ###
# Hostname (and optional port) where the app is served
# - local dev: localhost:3040
# - prod: drone-tm.example.com
DOMAIN=${DOMAIN:-localhost:3040}
# Frontend -> backend API base (must include /api)
# - local dev: http://localhost:8000/api
# - prod: https://<DOMAIN>/api
API_URL=${API_URL:-http://localhost:8000/api}


### PORTS (docker compose) ###
BACKEND_WEB_APP_PORT=${BACKEND_WEB_APP_PORT:-8000}
FRONTEND_WEB_APP_PORT=${FRONTEND_WEB_APP_PORT:-3040}


### DATABASE ###
POSTGRES_USER=${POSTGRES_USER:-dtm}
POSTGRES_DB=${POSTGRES_DB:-dtm_db}
POSTGRES_PASSWORD=${POSTGRES_PASSWORD:-dtm}
POSTGRES_HOST=${POSTGRES_HOST:-db}


### S3 (MINIO FOR LOCAL DEV, AWS S3 FOR PROD) ###
S3_BUCKET_NAME=${S3_BUCKET_NAME:-dtm-bucket}
S3_ACCESS_KEY=${S3_ACCESS_KEY:-SAMPLEACCESSKEY}
S3_SECRET_KEY=${S3_SECRET_KEY:-SAMPLESECRETACCESSKEY}

# Local dev default (minio). For AWS S3 set to e.g. https://s3.amazonaws.com
S3_ENDPOINT=${S3_ENDPOINT:-http://minio:9000}

# Optional: for local dev browser downloads when S3 endpoint is only reachable inside docker network
S3_DOWNLOAD_ROOT=${S3_DOWNLOAD_ROOT:-}


### JAXA ###
JAXA_AUTH_TOKEN=${JAXA_AUTH_TOKEN:-}


### REDIS / ARQ ###
REDIS_DSN=${REDIS_DSN:-redis://redis:6379/0}


### BACKEND ###
GOOGLE_CLIENT_ID=${GOOGLE_CLIENT_ID:-}
GOOGLE_CLIENT_SECRET=${GOOGLE_CLIENT_SECRET:-}

# Must match your Google OAuth app config
GOOGLE_LOGIN_REDIRECT_URI=${GOOGLE_LOGIN_REDIRECT_URI:-http://localhost:3040/auth}

SECRET_KEY=${SECRET_KEY:-}

# CORS
EXTRA_CORS_ORIGINS=${EXTRA_CORS_ORIGINS:-["http://localhost:3040"]}

NODE_ODM_URL=${NODE_ODM_URL:-http://nodeodm:9900}

DEBUG=${DEBUG:-True}

## Monitoring (OpenTelemetry) ##
MONITORING=${MONITORING}
SENTRY_DSN=${SENTRY_DSN}
LOG_LEVEL=${LOG_LEVEL:-INFO}

## SMTP CONFIG ##
SMTP_TLS=${SMTP_TLS:-True}
SMTP_SSL=${SMTP_SSL:-False}
SMTP_PORT=${SMTP_PORT:-587}
SMTP_HOST=${SMTP_HOST:-}
SMTP_USER=${SMTP_USER:-}
SMTP_PASSWORD=${SMTP_PASSWORD:-}
EMAILS_FROM_EMAIL=${EMAILS_FROM_EMAIL:-}
EMAILS_FROM_NAME=${EMAILS_FROM_NAME:-"Drone Tasking Manager"}

### compose.sub.yaml (VM reverse proxy) extras ###
CERT_EMAIL=${CERT_EMAIL:-}
GIT_BRANCH=${GIT_BRANCH:-main}

# Auto-detect nerdctl when docker is not installed (e.g. after `just prep machine`)
docker := env("DOCKER_ALIAS", if `command -v docker >/dev/null 2>&1 && echo found || echo missing` == "found" { "docker" } else { "nerdctl" })

# List available commands
[private]
default:
  just --justfile {{justfile()}} --list start

# Start Drone-TM (dev mode, local build)
[no-cd]
all:
  #!/usr/bin/env sh

  cd {{justfile_directory()}}
  {{docker}} compose up -d

# Prompt the user to select a release tag and export GIT_BRANCH.
# Exits if the working tree is dirty or no tags are found.
[no-cd]
_select-version:
  #!/usr/bin/env bash
  set -e

  cd {{justfile_directory()}}

  # Guard: refuse to deploy with uncommitted changes
  if ! git diff --quiet || ! git diff --cached --quiet; then
    just _echo-red "You have unstaged / uncommitted changes. Stash them first before deploy."
    exit 1
  fi

  # Fetch latest tags from remote
  git fetch --tags --quiet

  # Collect Drone-TM release tags (20xx.* with or without v prefix), most recent 8
  # Strip 'v' prefix for consistent numeric sorting, then restore original tag names
  mapfile -t tags < <(
    { git tag -l 'v20*'; git tag -l '20*'; } | sort -u |
    sed 's/^v//' | sort -t. -k1,1nr -k2,2nr -k3,3nr |
    while read -r t; do
      # Prefer the original tag name (check v-prefixed first, then bare)
      if git rev-parse "v${t}" >/dev/null 2>&1; then echo "v${t}"
      else echo "${t}"
      fi
    done | head -n 8
  )
  if [ ${#tags[@]} -eq 0 ]; then
    just _echo-red "No Drone-TM release tags found."
    exit 1
  fi

  # Prepend 'latest' option (uses dev branch with latest pre-built images)
  tags=("latest-unstable-dev" "${tags[@]}")

  echo ""
  chosen=$(just _select-menu "Select Drone-TM version:" "${tags[@]}")

  if [ "$chosen" = "latest-unstable-dev" ]; then
    just _echo-blue "Checking out dev branch (latest)..."
    git checkout dev
    echo "dev" > /tmp/.dtm_deploy_tag
  else
    just _echo-blue "Checking out ${chosen}..."
    git checkout "${chosen}"
    echo "${chosen}" > /tmp/.dtm_deploy_tag
  fi

# Production deploy from a tagged release (pre-built images)
[no-cd]
prod:
  #!/usr/bin/env bash
  set -e

  # Source exported env vars from .bashrc (e.g. CONTAINERD_SNAPSHOTTER)
  eval "$(grep '^export ' ~/.bashrc 2>/dev/null)" || true

  just start _select-version
  export GIT_BRANCH=$(cat /tmp/.dtm_deploy_tag)

  cd {{justfile_directory()}}

  # Generate .env if missing
  just config generate-dotenv "${GIT_BRANCH}"

  # Pull pre-built images for the selected tag
  just _echo-blue "Pulling images for ${GIT_BRANCH}..."
  ./envsubst -no-unset -i compose.sub.yaml | {{docker}} compose -f - pull

  # Deploy
  just _echo-blue "Deploying Drone-TM ${GIT_BRANCH}..."
  ./envsubst -no-unset -i compose.sub.yaml | \
        {{docker}} compose -f - up --detach \
        --remove-orphans --force-recreate

  just _echo-blue "Drone-TM ${GIT_BRANCH} started successfully"

# Start backend API only
[no-cd]
backend:
  #!/usr/bin/env sh

  cd {{justfile_directory()}}
  {{docker}} compose up -d backend

# Start frontend UI
[no-cd]
frontend:
  {{docker}} compose up -d frontend

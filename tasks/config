# Auto-detect nerdctl when docker is not installed (e.g. after `just prep machine`)
docker := env("DOCKER_ALIAS", if `command -v docker >/dev/null 2>&1 && echo found || echo missing` == "found" { "docker" } else { "nerdctl" })

# List available commands
[private]
default:
  just --justfile {{justfile()}} --list config

# Check if a dotenv variable is present
[no-cd]
[no-exit-message]
_dotenv-check key:
  #!/usr/bin/env sh
  if [ -z "${{ key }}" ]; then
      echo "Environment variable {{ key }} is not set."
      exit 1
  fi

# Update a variable in the .env file
[no-cd]
update-dotenv key value:
  #!/usr/bin/env sh

  var_name={{key}}
  var_value={{value}}
  var_pattern="^${var_name}="
  new_var="${var_name}=${var_value}"

  if grep -Eq "${var_pattern}" .env; then
    sed -i "s|${var_pattern}.*|${new_var}|" .env
  else
    echo "${new_var}" >> .env
  fi

# Generate the .env file from scratch, using .env.example and substitutions
[no-cd]
generate-dotenv branch="main":
  #!/usr/bin/env sh
  set -e

  cd {{justfile_directory()}}
  just prep envsubst

  if [ -f .env ]; then
    just _echo-yellow "'.env' already exists. Skipping generation."
  else
    # Generate a .env file from .env.example, substituting values from environment
    # NOTE: We run envsubst twice so defaults that reference other vars can be fully resolved.
    ./envsubst -i .env.example | ./envsubst | grep -vE '^\s*#|^\s*$' > .env
  fi

  # Export all variables from .env into the environment
  if [ -f .env ]; then
    set -a
    . ./.env
    set +a
  fi

  # Generate compose file (default main, but can be overridden)
  export GIT_BRANCH="{{ branch }}"
  echo ""
  just _echo-blue "Final compose file output for branch {{ branch }}:"
  echo ""
  # NOTE we run through envsubst twice for nested vars
  ./envsubst -i compose.sub.yaml | ./envsubst

# Interactive setup for production / self-hosted deployments
[no-cd]
setup:
  #!/usr/bin/env bash
  set -e

  cd {{justfile_directory()}}

  echo ""
  just _echo-blue "Drone-TM Production Setup"
  just _echo-blue "========================="
  echo ""
  echo "This will generate a .env file and configure it for your domain."
  echo "Secrets and database passwords are auto-generated."
  echo ""

  # Remove existing .env so generate-dotenv creates a fresh one
  rm -f .env
  just config generate-dotenv > /dev/null 2>&1

  # --- Domain ---
  printf "Enter your domain (e.g. dronetm.example.org): "
  read ftm_domain
  if [ -z "$ftm_domain" ]; then
    just _echo-red "Domain is required. Aborting."
    exit 1
  fi
  just config update-dotenv DOMAIN "$ftm_domain"

  # --- Cert email ---
  printf "Email for Let's Encrypt certificates: "
  read cert_email
  if [ -z "$cert_email" ]; then
    just _echo-red "Certificate email is required. Aborting."
    exit 1
  fi
  just config update-dotenv CERT_EMAIL "$cert_email"

  # --- Auth provider ---
  echo ""
  echo "Auth provider options:"
  echo "  1) hanko   - Hanko SSO (default, recommended)"
  echo "  2) legacy  - Google OAuth"
  printf "Select auth provider [1]: "
  read auth_choice
  case "$auth_choice" in
    2)
      just config update-dotenv AUTH_PROVIDER legacy
      printf "Google Client ID: "
      read google_id
      printf "Google Client Secret: "
      read google_secret
      just config update-dotenv GOOGLE_CLIENT_ID "$google_id"
      just config update-dotenv GOOGLE_CLIENT_SECRET "$google_secret"
      just config update-dotenv GOOGLE_LOGIN_REDIRECT_URI "https://$ftm_domain/auth"
      ;;
    *)
      just config update-dotenv AUTH_PROVIDER hanko
      printf "Hanko API URL [https://dev.login.hotosm.org]: "
      read hanko_url
      hanko_url="${hanko_url:-https://dev.login.hotosm.org}"
      just config update-dotenv HANKO_API_URL "$hanko_url"
      just config update-dotenv COOKIE_DOMAIN "$ftm_domain"
      ;;
  esac

  # --- S3 / Object storage ---
  echo ""
  just _echo-blue "S3 / Object Storage"
  printf "S3 endpoint URL [http://localhost:9000]: "
  read s3_endpoint
  s3_endpoint="${s3_endpoint:-http://localhost:9000}"
  just config update-dotenv S3_ENDPOINT_UPLOAD "$s3_endpoint"
  just config update-dotenv S3_ENDPOINT_DOWNLOAD "$s3_endpoint"

  printf "S3 bucket name [dtm-bucket]: "
  read s3_bucket
  s3_bucket="${s3_bucket:-dtm-bucket}"
  just config update-dotenv S3_BUCKET_NAME "$s3_bucket"

  printf "S3 access key: "
  read s3_access
  if [ -n "$s3_access" ]; then
    just config update-dotenv S3_ACCESS_KEY "$s3_access"
  fi

  printf "S3 secret key: "
  read s3_secret
  if [ -n "$s3_secret" ]; then
    just config update-dotenv S3_SECRET_KEY "$s3_secret"
  fi

  # --- Auto-generate secrets & passwords ---
  just config update-dotenv SECRET_KEY "$(openssl rand -base64 32)"
  just config update-dotenv POSTGRES_PASSWORD "$(openssl rand -base64 24)"

  # Production defaults
  just config update-dotenv DEBUG "False"
  just config update-dotenv EXTRA_CORS_ORIGINS "https://$ftm_domain"

  echo ""
  just _echo-blue "Setup complete. Config written to .env"
  echo ""
  just _echo-yellow "Review .env as needed, then run: just start prod"
  echo ""

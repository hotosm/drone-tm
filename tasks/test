# Auto-detect nerdctl when docker is not installed (e.g. after `just prep machine`)
docker := env("DOCKER_ALIAS", if `command -v docker >/dev/null 2>&1 && echo found || echo missing` == "found" { "docker" } else { "nerdctl" })

# List available commands
[private]
default:
  just --justfile {{justfile()}} --list test

# Test backend
[no-cd]
backend:
    {{docker}} compose -f compose.test.yaml build backend
    # Must run separately to avoid exit 0 from createbuckets
    {{docker}} compose -f compose.test.yaml run --rm createbuckets
    {{docker}} compose -f compose.test.yaml up --detach --wait backend arq-worker
    # We run like this to ensure correct cleanup after tests done (or early exit)
    sh -c 'trap "just test backend-cleanup || true" EXIT; {{docker}} compose -f compose.test.yaml exec -T backend pytest'

# Cleanup orphan backend tests
[no-cd]
backend-cleanup:
    {{docker}} compose -f compose.test.yaml down --remove-orphans

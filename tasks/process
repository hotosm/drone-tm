set dotenv-load

# Auto-detect nerdctl when docker is not installed (e.g. after `just prep machine`)
docker := env("DOCKER_ALIAS", if `command -v docker >/dev/null 2>&1 && echo found || echo missing` == "found" { "docker" } else { "nerdctl" })

# DroneTM S3 config (from .env)
dtm_endpoint := env("S3_ENDPOINT_UPLOAD", "http://localhost:9000")
dtm_bucket   := env("S3_BUCKET_NAME", "dtm-bucket")
dtm_access   := env("S3_ACCESS_KEY", "admin")
dtm_secret   := env("S3_SECRET_KEY", "somelongpassword")

# List available commands
[private]
default:
  just --justfile {{justfile()}} --list process

# Runs rclone in a docker container - no volume mounts needed (S3-to-S3).
# Uses --checksum for efficient delta sync.
#
# After copying, open the Upload Imagery dialog in the DroneTM UI and click
# "Ingest Existing S3 Imagery" to load the files into the database.
# Then proceed to the Classify dialog as normal.
#
# Credentials and endpoint are optional:
#   - Omit credentials for public buckets (uses anonymous/unsigned requests).
#   - Omit endpoint to target standard AWS S3; provide it for S3-compatible services.
#
# Usage:
#   just process import-imagery <project_id> <src_bucket> <src_prefix> \
#       [src_endpoint] [src_access_key] [src_secret_key]
#
# Examples:
#   # DroneTM public test data (AWS S3, no credentials needed)
#   just process import-imagery abc-123-def dronetm-testdata surveys/2026-04
#
#   # Private AWS S3 bucket
#   just process import-imagery abc-123-def \
#       my-bucket surveys/2026-04/flight-data \
#       "" AKIAEXAMPLE wJalrXUtnFEMI/EXAMPLEKEY
#
#   # Private S3-compatible service
#   just process import-imagery abc-123-def \
#       source-bucket raw-images \
#       http://rustfs-endpoint:9000 otheradmin otherpassword
#
#   # Public S3-compatible service (no credentials)
#   just process import-imagery abc-123-def \
#       public-bucket raw-images \
#       http://rustfs-endpoint:9000
#
# Copy imagery from an external S3 path into a DroneTM project's user-uploads dir.
import-imagery project_id src_bucket src_prefix src_endpoint="" src_access_key="" src_secret_key="":
  #!/usr/bin/env bash
  set -euo pipefail

  DEST="{{ dtm_bucket }}/projects/{{ project_id }}/user-uploads/"
  ACCESS="{{ src_access_key }}"
  SECRET="{{ src_secret_key }}"
  ENDPOINT="{{ src_endpoint }}"

  # Build source remote config as Docker -e flags to avoid rclone connection-string
  # parsing issues with URLs containing '://' (the colon is the config/path delimiter).
  SRC_ENV=(-e RCLONE_CONFIG_SRC_TYPE=s3)

  if [ -n "$ENDPOINT" ]; then
    SRC_ENV+=(-e RCLONE_CONFIG_SRC_PROVIDER=Other -e "RCLONE_CONFIG_SRC_ENDPOINT=${ENDPOINT}")
  else
    # No endpoint = standard AWS S3; rclone requires an explicit provider value.
    SRC_ENV+=(-e RCLONE_CONFIG_SRC_PROVIDER=AWS)
  fi

  if [ -n "$ACCESS" ] && [ -n "$SECRET" ]; then
    SRC_ENV+=(-e "RCLONE_CONFIG_SRC_ACCESS_KEY_ID=${ACCESS}" -e "RCLONE_CONFIG_SRC_SECRET_ACCESS_KEY=${SECRET}")
    echo "==> Copying imagery (authenticated)"
  else
    SRC_ENV+=(-e RCLONE_CONFIG_SRC_NO_SIGN_REQUEST=true)
    echo "==> Copying imagery (public / anonymous)"
  fi

  echo "    Source: {{ src_bucket }}/{{ src_prefix }}"
  echo "    Dest:   ${DEST}"
  echo "    Source endpoint: ${ENDPOINT:-https://s3.amazonaws.com}"
  echo "    Dest endpoint:   {{ dtm_endpoint }}"
  echo ""

  {{ docker }} run --rm --network host \
    "${SRC_ENV[@]}" \
    -e RCLONE_CONFIG_DTM_TYPE=s3 \
    -e RCLONE_CONFIG_DTM_PROVIDER=Other \
    -e "RCLONE_CONFIG_DTM_ENDPOINT={{ dtm_endpoint }}" \
    -e "RCLONE_CONFIG_DTM_ACCESS_KEY_ID={{ dtm_access }}" \
    -e "RCLONE_CONFIG_DTM_SECRET_ACCESS_KEY={{ dtm_secret }}" \
    -e RCLONE_CONFIG_DTM_NO_CHECK_BUCKET=true \
    rclone/rclone:latest \
    copy \
      "src:{{ src_bucket }}/{{ src_prefix }}" \
      "dtm:${DEST}" \
      --checksum \
      --include "*.jpg" --include "*.JPG" --include "*.jpeg" --include "*.JPEG" \
      --include "*.tif" --include "*.TIF" --include "*.tiff" --include "*.TIFF" \
      --include "*.png" --include "*.PNG" --include "*.dng"  --include "*.DNG" \
      --transfers 8 \
      --progress \
      -v

  echo ""
  echo "==> Copy complete."
  echo "    Open the Upload Imagery dialog in the DroneTM UI and click"
  echo "    'Ingest Existing S3 Imagery' to load files into the database."
